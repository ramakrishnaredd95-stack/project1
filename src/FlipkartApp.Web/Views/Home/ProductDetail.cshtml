@model FlipkartApp.Core.DTOs.ProductDto
@{
    ViewData["Title"] = Model.Name;
}

<div class="section" style="padding: 24px;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
        <div style="text-align: center; padding: 24px;">
            <img src="@Model.ImageUrl" alt="@Model.Name" style="max-width: 400px; max-height: 400px; object-fit: contain;" onerror="this.src='https://via.placeholder.com/400x400?text=Product'" />
        </div>
        <div>
            <p style="color: #878787; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px;">@Model.Brand</p>
            <h1 style="font-size: 18px; font-weight: 500; margin: 8px 0;">@Model.Name</h1>
            <div class="rating" style="margin: 8px 0;">@Model.Rating ★ | @Model.ReviewCount Ratings</div>
            <div style="margin: 16px 0;">
                <span style="font-size: 28px; font-weight: 600;">₹@Model.DiscountPrice.ToString("N0")</span>
                <span style="text-decoration: line-through; color: #878787; font-size: 16px; margin-left: 12px;">₹@Model.Price.ToString("N0")</span>
                @{ var discount = Math.Round((1 - (double)Model.DiscountPrice / (double)Model.Price) * 100); }
                <span style="color: #388e3c; font-size: 16px; font-weight: 500; margin-left: 12px;">@(discount)% off</span>
            </div>
            <p style="color: #212121; line-height: 1.6; margin: 16px 0;">@Model.Description</p>
            <p style="color: #878787; font-size: 13px;">Category: @Model.CategoryName</p>
            <p style="color: @(Model.StockQuantity > 0 ? "#388e3c" : "#ff6161"); font-size: 14px; font-weight: 500; margin: 8px 0;">
                @(Model.StockQuantity > 0 ? "In Stock" : "Out of Stock")
            </p>
            <div style="display: flex; gap: 16px; margin-top: 24px;">
                <button style="background: #ff9f00; color: white; border: none; padding: 14px 32px; font-size: 16px; font-weight: 600; border-radius: 4px; cursor: pointer;">🛒 ADD TO CART</button>
                <button style="background: #fb641b; color: white; border: none; padding: 14px 32px; font-size: 16px; font-weight: 600; border-radius: 4px; cursor: pointer;">⚡ BUY NOW</button>
            </div>
        </div>
    </div>
</div>
